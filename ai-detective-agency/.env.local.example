# ============================================================
# AI Detective Agency — Environment Variables Template
# ============================================================
# 1. Copy this file:   cp .env.local.example .env.local
# 2. Fill in the values below
# 3. NEVER commit .env.local to version control
# ============================================================

# ------------------------------------------------------------
# NextAuth.js — REQUIRED
# ------------------------------------------------------------

# Secret used to sign/encrypt JWT tokens.
# Generate one with:  openssl rand -base64 32
# Or online at:       https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=

# The canonical URL of your app (no trailing slash).
# In production replace with your deployed URL.
NEXTAUTH_URL=http://localhost:3000

# ------------------------------------------------------------
# Google Gemini AI — REQUIRED for AI agent features
# ------------------------------------------------------------

# Get your free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ------------------------------------------------------------
# Optional / future use
# ------------------------------------------------------------

# Uncomment when you add a real database (e.g. Prisma + PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_detective

# Public app config (safe to expose to the browser)
# NEXT_PUBLIC_APP_NAME=AI Detective Agency
# NEXT_PUBLIC_APP_URL=http://localhost:3000
